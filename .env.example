# OCR provider settings
OCR_PROVIDER=tesseract
TESSERACT_CMD=

# Pipeline defaults
DEFAULT_INPUT_DIR=data/inbox
DEFAULT_OUTPUT_FILE=data/output/Expenses.csv
DEFAULT_MODEL_FILE=models/model.csv
DEFAULT_EXAMPLE_FILE=models/example.csv

# Optional runtime observability
RECEIPT_PROCESSOR_LOG_DIR=logs
RECEIPT_PROCESSOR_LOG_PRIVACY_MODE=standard

# Optional runtime controls
RECEIPT_PROCESSOR_RISK_CONTROLS_FILE=configs/risk_controls.yaml

# Optional LLM extraction (enabled by default; disable per preference)
ENABLE_LLM=true
ENABLE_LLM_EXCEPTION_ASSIST=true
OPENROUTER_API_KEY=REPLACE_WITH_YOUR_TOKEN
OPENROUTER_MODEL=openrouter/free
LLM_INPUT_MODE=text

# Optional LLM tuning
LLM_TIMEOUT_SECONDS=30
LLM_MAX_INPUT_CHARS=12000
LLM_MAX_FILE_BYTES=5000000
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=ReceiptProcessor
OPENROUTER_PDF_ENGINE=
# Optional cost hints for log estimation only
OPENROUTER_INPUT_COST_PER_1K_TOKENS=
OPENROUTER_OUTPUT_COST_PER_1K_TOKENS=
